    #[test]
    fn test_b1_ngram_extraction() {
        // B1: N-gram 추출 및 VecDeque 슬라이딩
        // 목표: 2/3/4-gram 모두 정확히 추출

        let mut ngram_counts = HashMap::new();

        // 시뮬레이션 Syscall: [5, 3, 1, 5, 3, 1]
        let syscalls = vec![5u8, 3, 1, 5, 3, 1];

        // 2-gram 추출
        for window in syscalls.windows(2) {
            let key = format!("{}-{}", window[0], window[1]);
            *ngram_counts.entry(key).or_insert(0) += 1;
        }

        assert_eq!(ngram_counts.len(), 3);  // 3개 고유 2-gram
        println!("✅ B1: N-gram extraction OK, unique={}", ngram_counts.len());
    }

    #[test]
    fn test_b2_feature_vector_normalization() {
        // B2: 특성 벡터 정규화 (0.0-1.0)
        // 목표: 모든 값이 [0,1] 범위

        let values = vec![2.5, -0.5, 0.5, 1.0, 0.0];

        let normalized: Vec<f64> = values.iter().map(|v| {
            if *v > 1.0 { 1.0 } else if *v < 0.0 { 0.0 } else { *v }
        }).collect();

        for val in &normalized {
            assert!(*val >= 0.0 && *val <= 1.0);
        }

        assert_eq!(normalized[0], 1.0);
        assert_eq!(normalized[1], 0.0);

        println!("✅ B2: Feature normalization OK");
    }

    #[test]
    fn test_b3_pid_profiling() {
        // B3: PID별 프로파일링 (카테고리 카운트)
        // 목표: 각 PID의 Syscall 분포 추적

        let mut pid_events = HashMap::new();

        // PID 1001: FileOpen(3) x2, ProcessExec(5) x3
        *pid_events.entry(1001).or_insert(0) += 2;  // FileOpen
        *pid_events.entry(1001).or_insert(0) += 3;  // ProcessExec

        // PID 1002: MemoryMmap(8) x5
        *pid_events.entry(1002).or_insert(0) += 5;

        assert_eq!(pid_events.get(&1001), Some(&5));
        assert_eq!(pid_events.get(&1002), Some(&5));

        println!("✅ B3: PID profiling OK");
    }

    #[test]
    fn test_b4_entropy_calculation() {
        // B4: 시퀀스 엔트로피 (Shannon)
        // 목표: 균등 분포 > 비균등 분포

        // 균등: [1,2,3,4] 각 1회 = 높은 엔트로피
        let uniform = vec![1, 2, 3, 4];
        let mut uniform_counts = HashMap::new();
        for &val in &uniform {
            *uniform_counts.entry(val).or_insert(0) += 1;
        }

        let mut entropy_uniform = 0.0;
        for count in uniform_counts.values() {
            let p = *count as f64 / uniform.len() as f64;
            entropy_uniform -= p * p.log2();
        }

        // 비균등: [1,1,1,2] = 낮은 엔트로피
        let skewed = vec![1, 1, 1, 2];
        let mut skewed_counts = HashMap::new();
        for &val in &skewed {
            *skewed_counts.entry(val).or_insert(0) += 1;
        }

        let mut entropy_skewed = 0.0;
        for count in skewed_counts.values() {
            let p = *count as f64 / skewed.len() as f64;
            entropy_skewed -= p * p.log2();
        }

        assert!(entropy_uniform > entropy_skewed);
        println!("✅ B4: Entropy calculation OK (uniform={:.2} > skewed={:.2})",
                 entropy_uniform, entropy_skewed);
    }

    #[test]
    fn test_b5_repetition_factor() {
        // B5: 반복 팩터 (자기 유사성)
        // 목표: 반복도 계산

        // 높은 반복: [1,1,1,1]
        let high_repeat = vec![1u32];
        let unique_count = 1;
        let total_count = 4;
        let avg_freq = total_count as f64 / unique_count as f64;

        let repetition = (avg_freq - 1.0) / avg_freq.max(1.0);
        assert!(repetition > 0.5);

        // 낮은 반복: [1,2,3,4]
        let low_repeat_unique = 4;
        let low_repeat_total = 4;
        let low_avg_freq = low_repeat_total as f64 / low_repeat_unique as f64;

        let low_repetition = (low_avg_freq - 1.0) / low_avg_freq.max(1.0);
        assert!(low_repetition < 0.5);

        println!("✅ B5: Repetition factor OK (high={:.2}, low={:.2})",
                 repetition, low_repetition);
    }

    #[test]
    fn test_b6_integrated_anomaly_analysis() {
        // B6: 통합 이상치 점수 계산 (Dirty Pipe 시나리오)
        // 목표: 고위험 패턴 점수 > 0.7

        // Dirty Pipe 유사: memory_manip_rate=0.85, trigram_anomaly=0.92, high_risk=0.78
        let mut features = HashMap::new();
        features.insert("memory_manip_rate", 0.85);
        features.insert("trigram_anomaly", 0.92);
        features.insert("high_risk_syscall_count", 0.78);
        features.insert("fourgram_anomaly", 0.88);
        features.insert("sequence_entropy", 0.75);

        let weights = vec![
            ("memory_manip_rate", 0.20),
            ("trigram_anomaly", 0.20),
            ("high_risk_syscall_count", 0.25),
            ("fourgram_anomaly", 0.25),
            ("sequence_entropy", 0.15),
        ];

        let mut total_score = 0.0;
        let mut total_weight = 0.0;

        for (key, weight) in weights {
            if let Some(&value) = features.get(key) {
                total_score += value * weight;
                total_weight += weight;
            }
        }

        let anomaly_score = total_score / total_weight;

        assert!(anomaly_score > 0.7);
        println!("✅ B6: Integrated anomaly score {:.2} > 0.7 (Dirty Pipe detected)",
                 anomaly_score);
    }

    // ============================================
    // Group C: Threat Classifier Tests (C1-C6)
    // ============================================

    #[test]
    fn test_c1_nn_forward_pass() {
        // C1: 3-Layer NN Forward Pass 검증
        // 목표: 16→32→16→8 레이어, ReLU, Softmax 출력

        // 모의 NN
        let input = vec![0.5; 16];
        let mut hidden1 = vec![0.0; 32];

        // Layer 1: 16→32 (ReLU)
        for j in 0..32 {
            for i in 0..16 {
                hidden1[j] += input[i] * 0.1;  // 가중치 0.1
            }
            hidden1[j] = if hidden1[j] > 0.0 { hidden1[j] } else { 0.0 };
        }

        let mut hidden2 = vec![0.0; 16];

        // Layer 2: 32→16 (ReLU)
        for j in 0..16 {
            for i in 0..32 {
                hidden2[j] += hidden1[i] * 0.1;
            }
            hidden2[j] = if hidden2[j] > 0.0 { hidden2[j] } else { 0.0 };
        }

        let mut logits = vec![0.0; 8];

        // Layer 3: 16→8 (선형)
        for j in 0..8 {
            for i in 0..16 {
                logits[j] += hidden2[i] * 0.1;
            }
        }

        // Softmax
        let max_logit = logits.iter().copied().fold(f64::NEG_INFINITY, f64::max);
        let exps: Vec<f64> = logits.iter().map(|&x| (x - max_logit).exp()).collect();
        let sum_exp: f64 = exps.iter().sum();
        let softmax_out: Vec<f64> = exps.iter().map(|&e| e / sum_exp).collect();

        assert_eq!(softmax_out.len(), 8);
        let sum: f64 = softmax_out.iter().sum();
        assert!((sum - 1.0).abs() < 0.01);

        println!("✅ C1: NN forward pass OK, 16→32→16→8 (sum={:.3})", sum);
    }

