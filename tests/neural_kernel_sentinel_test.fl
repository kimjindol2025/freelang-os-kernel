    #[test]
    fn test_d1_policy_based_decision() {
        // D1: 정책 기반 대응 결정
        // 목표: 신뢰도별로 다른 액션 (경고 < 샘플링 < 격리 < 종료)

        // 신뢰도 0.5: Alert
        let mut engine_decisions = HashMap::new();
        engine_decisions.insert("low", "Alert");

        // 신뢰도 0.75: IncreaseSampling
        engine_decisions.insert("medium", "IncreaseSampling");

        // 신뢰도 0.85: IsolatePid
        engine_decisions.insert("high", "IsolatePid");

        // 신뢰도 0.95: KillPid
        engine_decisions.insert("critical", "KillPid");

        assert_eq!(engine_decisions.len(), 4);
        println!("✅ D1: Policy-based decisions OK");
