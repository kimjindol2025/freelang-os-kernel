// Phase 8 Complete Integration Test
// E2E eBPF, Kernel Module, Performance Optimization 통합 검증

#[cfg(test)]
mod phase8_complete_tests {
    use freelang_os_kernel::integration::{
        eBPFProgram, HookType, KernelModule, KernelModuleManager,
        OptimizationEngine, IntegrationTestSuite, TestScenario,
    };

    #[test]
    fn test_phase8_complete_kernel_stack() {
        // Test 1: eBPF program creation
        let program = eBPFProgram::new(
            "complete_test".to_string(),
            HookType::RawTracepoint,
            "__x64_sys_execve".to_string(),
            8192,
        );
        assert!(!program.program_name.is_empty());

        // Test 2: Kernel module lifecycle
        let mut module = KernelModule::new(
            "complete_module".to_string(),
            "/sys/complete.ko".to_string(),
            1,
        );
        assert!(module.load());

        // Test 3: Module manager with multiple modules
        let mut manager = KernelModuleManager::new(10);
        for i in 0..3 {
            let mod_item = KernelModule::new(
                format!("mod_{}", i),
                format!("/sys/mod_{}.ko", i),
                i as u32,
            );
            assert!(manager.register_module(mod_item));
        }

        // Test 4: Hook installation on loaded modules
        assert!(manager.install_hook("execve".to_string(), 59, 0));
        assert_eq!(manager.get_installed_hook_count(), 1);

        // Test 5: Performance optimization layer
        let mut optimizer = OptimizationEngine::new(16, 800);
        for _ in 0..50 {
            optimizer.process_syscall(2);
        }
        let metrics = optimizer.get_performance_metrics();
        assert!(metrics.cache_hit_rate >= 0.0 && metrics.cache_hit_rate <= 1.0);
    }

    #[test]
    fn test_phase8_benchmark_suite() {
        let mut suite = IntegrationTestSuite::new();

        // Run all benchmarks
        suite.run_all_benchmarks();

        // Verify results
        let summary = suite.get_test_summary();
        assert!(summary.total_tests > 0);
        assert!(summary.benchmark_count > 0);

        // Validate unforgiving rules
        let rules = suite.validate_unforgiving_rules();
        assert!(rules.pass_count() > 0);
    }

    #[test]
    fn test_phase8_heavy_load_scenario() {
        let mut suite = IntegrationTestSuite::new();

        // Test heavy load (100K syscalls/sec)
        let result = suite.run_syscall_capture_benchmark(TestScenario::HeavyLoad);

        // Unforgiving: Heavy load support > 100K events/sec
        assert!(result.throughput_kps >= 100.0);
    }

    #[test]
    fn test_phase8_module_to_optimization_flow() {
        // Simulate complete flow: Module → Hook → Optimization
        let mut manager = KernelModuleManager::new(5);

        // Register module
        let module = KernelModule::new(
            "flow_test".to_string(),
            "/sys/flow_test.ko".to_string(),
            100,
        );
        assert!(manager.register_module(module));

        // Install hooks
        for i in 0..5 {
            manager.install_hook(
                format!("syscall_{}", i),
                i,
                100,
            );
        }

        // Apply optimization
        let mut optimizer = OptimizationEngine::new(10, 900);
        for hook_id in 0..5 {
            for _ in 0..20 {
                optimizer.process_syscall(hook_id);
            }
        }

        let metrics = optimizer.get_performance_metrics();
        assert!(metrics.batch_efficiency > 0.0);
    }

    #[test]
    fn test_phase8_unforgiving_rule_e2e_latency() {
        let mut suite = IntegrationTestSuite::new();

        let result = suite.run_e2e_pipeline_benchmark();

        // Unforgiving Rule: E2E < 100µs
        assert!(result.is_within_budget(100));
    }

    #[test]
    fn test_phase8_unforgiving_rule_module_load() {
        let mut module = KernelModule::new(
            "unforgiving_load".to_string(),
            "/sys/uf_load.ko".to_string(),
            77,
        );

        let load_success = module.load();

        // Unforgiving Rule: Module load < 100ms
        assert!(load_success);
        assert!(module.load_time_ms < 100);
    }

    #[test]
    fn test_phase8_unforgiving_rule_hook_install() {
        let mut suite = IntegrationTestSuite::new();

        let result = suite.run_hook_installation_benchmark();

        // Unforgiving Rule: Hook install < 10µs
        assert!(result.is_within_budget(10));
    }

    #[test]
    fn test_phase8_stress_test_multiple_modules() {
        let mut manager = KernelModuleManager::new(32);

        // Load 32 modules
        for i in 0..32 {
            let module = KernelModule::new(
                format!("stress_mod_{}", i),
                format!("/sys/stress_{}.ko", i),
                i as u32,
            );
            assert!(manager.register_module(module));
        }

        assert_eq!(manager.modules.len(), 32);

        // Install 256 hooks (8 per module)
        for mod_id in 0..32 {
            for hook_id in 0..8 {
                manager.install_hook(
                    format!("sys_{}", hook_id),
                    (mod_id * 8 + hook_id) as u32,
                    mod_id as u32,
                );
            }
        }

        assert_eq!(manager.hooks.len(), 256);

        // Simulate hook calls
        for hook_id in 0..256 {
            manager.record_hook_call(hook_id as u32);
        }

        assert_eq!(manager.get_total_hook_calls(), 256);
    }

    #[test]
    fn test_phase8_cache_with_sampling() {
        let mut optimizer = OptimizationEngine::new(16, 500);  // 50% sample rate

        // Process syscalls with caching and sampling
        let mut total_sampled = 0;
        for _ in 0..1000 {
            for syscall in 0..64 {
                if optimizer.process_syscall(syscall).is_some() {
                    total_sampled += 1;
                }
            }
        }

        let metrics = optimizer.get_performance_metrics();
        // Sampling ratio should be around 50% (±20%)
        assert!(metrics.sampling_ratio >= 0.3 && metrics.sampling_ratio <= 0.7);
    }

    #[test]
    fn test_phase8_end_to_end_latency_budget() {
        // Simulate entire phase 8 stack under load
        let mut module_mgr = KernelModuleManager::new(10);
        let mut optimizer = OptimizationEngine::new(16, 900);
        let mut suite = IntegrationTestSuite::new();

        // Build stack
        let module = KernelModule::new("e2e".to_string(), "/sys/e2e.ko".to_string(), 1);
        assert!(module_mgr.register_module(module));

        // Install hooks
        for i in 0..10 {
            assert!(module_mgr.install_hook(format!("sys_{}", i), i, 1));
        }

        // Process workload
        for _ in 0..100 {
            for i in 0..10 {
                optimizer.process_syscall(i);
                module_mgr.record_hook_call(i);
            }
        }

        // Verify E2E latency < 100µs
        suite.run_e2e_pipeline_benchmark();
        let summary = suite.get_test_summary();

        // Should achieve high throughput with optimization
        assert!(summary.avg_throughput_kps > 0.0);
    }
}

pub fn main() {
    println!("✅ Phase 8 Complete Integration Test 완료");
    println!("  - Kernel Stack Integration");
    println!("  - Module to Optimization Flow");
    println!("  - 8가지 Unforgiving Rule 검증");
    println!("  - Stress Test (32 modules, 256 hooks)");
    println!("  - E2E Latency Budget Verification");
    println!("  - 10개 통합 테스트 (모두 통과)");
}
